{
  "manifest_version": 3,
  "name": "Vault Advisor — Tier Badge (prototype)",
  "version": "0.1.0",
  "description": "Injects a tier badge into DIM's item popup, looked up from the community tier sheet.",
  "permissions": ["storage"],
  "host_permissions": ["https://docs.google.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vault Advisor — tier search"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://app.destinyitemmanager.com/*", "https://beta.destinyitemmanager.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "vault-advisor-tier-badge@vault-advisor.local",
      "strict_min_version": "126.0"
    }
  }
}
